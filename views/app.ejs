<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMS · <%= page.replace(/_/g, ' ') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --sidebar-bg: #1B1C31;
            --sidebar-hover: #2B2DFB;
            --bg-color: #F4F7FE;
            --text-main: #2B3674;
            --text-muted: #A3AED0;
            --card-radius: 20px;
        }
        body { font-family: 'Inter', sans-serif; background: var(--bg-color); color: var(--text-main); }

        /* Sidebar */
        .sidebar {
            position: fixed; top: 0; left: 0; width: 280px; height: 100vh;
            background: var(--sidebar-bg); padding: 25px 20px;
            overflow-y: auto; z-index: 1000; display: flex; flex-direction: column;
        }
        .brand-box { display: flex; align-items: center; gap: 12px; margin-bottom: 35px; padding: 0 8px; }
        .brand-logo {
            width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
            background: linear-gradient(135deg, #FF9C00, #FFC048);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: 18px;
        }
        .brand-text h6 { color: #fff; margin: 0; font-weight: 700; font-size: 15px; }
        .brand-text small { color: var(--text-muted); font-size: 11px; }
        .nav-header {
            color: var(--text-muted); font-size: 11px; font-weight: 600;
            letter-spacing: 1px; text-transform: uppercase; margin: 20px 8px 8px 8px;
        }
        .sidebar .nav-link {
            color: #B8B9CB; font-size: 14px; padding: 11px 14px; border-radius: 12px;
            display: flex; align-items: center; gap: 12px; margin-bottom: 4px; transition: all .2s;
        }
        .sidebar .nav-link i { width: 18px; text-align: center; }
        .sidebar .nav-link:hover { background: rgba(43, 45, 251, 0.25); color: #fff; }
        .sidebar .nav-link.active { background: var(--sidebar-hover); color: #fff; }
        .sidebar .nav-link.logout-link { color: #FF6B6B; }
        .sidebar .nav-link.logout-link:hover { background: rgba(255, 107, 107, 0.15); color: #FF6B6B; }
        .trophy-card {
            background: linear-gradient(135deg, #2B2DFB, #6366F1);
            border-radius: 16px; padding: 20px; text-align: center;
            color: #fff; margin-top: auto; margin-bottom: 15px;
        }
        .trophy-card i { font-size: 26px; color: #FFC048; margin-bottom: 8px; }

        /* Main */
        .main-content { margin-left: 280px; padding: 25px 30px; }
        .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; flex-wrap: wrap; gap: 15px; }
        .page-title { font-weight: 700; text-transform: capitalize; margin: 0; }
        .welcome-text { color: var(--text-muted); font-size: 13px; }
        .topbar-tools { display: flex; align-items: center; gap: 10px; background: #fff; border-radius: 30px; padding: 8px 10px; box-shadow: 0 10px 30px rgba(112,144,176,0.10); }
        .search-box { background: var(--bg-color); border-radius: 30px; padding: 6px 15px; display: flex; align-items: center; gap: 8px; }
        .search-box input { border: none; background: transparent; outline: none; font-size: 13px; width: 140px; }
        .icon-btn { width: 36px; height: 36px; border-radius: 50%; border: none; background: transparent; color: var(--text-muted); position: relative; }
        .icon-btn .badge-dot {
            position: absolute; top: 2px; right: 2px; background: #FF4C61; color: #fff;
            font-size: 9px; border-radius: 50%; width: 15px; height: 15px;
            display: flex; align-items: center; justify-content: center;
        }
        .profile-btn { display: flex; align-items: center; gap: 10px; border: none; background: transparent; text-align: left; }
        .profile-btn img { width: 36px; height: 36px; border-radius: 50%; }
        .profile-btn .p-name { font-size: 13px; font-weight: 600; color: var(--text-main); line-height: 1.1; }
        .profile-btn .p-role { font-size: 11px; color: var(--text-muted); text-transform: capitalize; }

        /* Cards */
        .card { border: none; border-radius: var(--card-radius); box-shadow: 0 10px 30px rgba(112,144,176,0.08); }
        .card-header { background: #fff; border-bottom: 1px solid #F1F4F9; border-radius: var(--card-radius) var(--card-radius) 0 0 !important; font-weight: 700; }
        .table th { color: var(--text-muted); font-size: 12px; text-transform: uppercase; font-weight: 600; border: none; }
        .table td { vertical-align: middle; font-size: 14px; color: var(--text-main); }
        .form-label { font-size: 13px; font-weight: 600; }
        .form-control, .form-select { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 12px; font-size: 14px; }
        .form-control:focus, .form-select:focus { border-color: #6366F1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }

        /* Metric cards */
        .metric-card { border-radius: var(--card-radius); color: #fff; padding: 22px; position: relative; overflow: hidden; }
        .metric-card .m-icon {
            width: 46px; height: 46px; border-radius: 50%; background: rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 12px;
        }
        .metric-card h3 { font-weight: 700; margin: 0; }
        .metric-card small { opacity: .85; font-size: 12px; }
        .bg-purple { background: linear-gradient(135deg, #6366F1, #818CF8); }
        .bg-green  { background: linear-gradient(135deg, #00B87C, #34D39E); }
        .bg-orange { background: linear-gradient(135deg, #FF9C00, #FFC048); }
        .bg-blue   { background: linear-gradient(135deg, #0075FF, #4DA3FF); }
        .bg-pink   { background: linear-gradient(135deg, #FF4C61, #FF7E8D); }

        .status-pill { font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 20px; }
        .pill-green { background: #E6F9F1; color: #00B87C; }
        .pill-red   { background: #FFECEE; color: #FF4C61; }
        .pill-yellow{ background: #FFF6E0; color: #E5A100; }

        .avatar-sm { width: 34px; height: 34px; border-radius: 50%; }
        .notif-card { background: #fff; border-radius: 16px; padding: 18px 20px; box-shadow: 0 10px 30px rgba(112,144,176,0.08); display: flex; gap: 15px; align-items: flex-start; margin-bottom: 12px; }
        .notif-icon { width: 42px; height: 42px; border-radius: 12px; background: #EEF0FF; color: #6366F1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .score-card { background: #fff; border-radius: var(--card-radius); box-shadow: 0 10px 30px rgba(112,144,176,0.08); border-top: 5px solid #6366F1; padding: 25px; text-align: center; }
        .btn-indigo { background: #6366F1; color: #fff; border-radius: 12px; }
        .btn-indigo:hover { background: #4F46E5; color: #fff; }
    </style>
</head>
<body>

<!-- ================= SIDEBAR ================= -->
<div class="sidebar">
    <div class="brand-box">
        <div class="brand-logo">S</div>
        <div class="brand-text">
            <h6>SMS</h6>
            <small>Management System</small>
        </div>
    </div>

    <a href="/app?page=dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i> Dashboard
    </a>

    <% if (user.role === 'admin') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=courses" class="nav-link <%= page === 'courses' ? 'active' : '' %>"><i class="fa-solid fa-book"></i> Courses</a>
        <a href="/app?page=subjects" class="nav-link <%= page === 'subjects' ? 'active' : '' %>"><i class="fa-solid fa-book-open"></i> Subjects</a>
        <a href="/app?page=manage_attendance" class="nav-link <%= page === 'manage_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> Manage Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Manage Exams</a>
        <div class="nav-header">Users</div>
        <a href="/app?page=manage_staff" class="nav-link <%= page === 'manage_staff' ? 'active' : '' %>"><i class="fa-solid fa-user-tie"></i> Manage Staff</a>
        <a href="/app?page=manage_students" class="nav-link <%= page === 'manage_students' ? 'active' : '' %>"><i class="fa-solid fa-user-graduate"></i> Manage Students</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=notifications" class="nav-link <%= page === 'notifications' ? 'active' : '' %>"><i class="fa-solid fa-envelope-open-text"></i> Leave Requests</a>
        <a href="/app?page=notify" class="nav-link <%= page === 'notify' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn"></i> Send Notice</a>
    <% } else if (user.role === 'staff') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=take_attendance" class="nav-link <%= page === 'take_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-check"></i> Take Attendance</a>
        <a href="/app?page=view_attendance" class="nav-link <%= page === 'view_attendance' ? 'active' : '' %>"><i class="fa-solid fa-list-check"></i> View Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Manage Exams</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <div class="nav-header">Others</div>
        <a href="/app?page=staff_notifs" class="nav-link <%= page === 'staff_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
    <% } else { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=my_attendance" class="nav-link <%= page === 'my_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> My Attendance</a>
        <a href="/app?page=exam_results" class="nav-link <%= page === 'exam_results' ? 'active' : '' %>"><i class="fa-solid fa-square-poll-vertical"></i> Exam Results</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <div class="nav-header">Others</div>
        <a href="/app?page=student_notifs" class="nav-link <%= page === 'student_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
        <a href="/app?page=feedback" class="nav-link <%= page === 'feedback' ? 'active' : '' %>"><i class="fa-solid fa-comment-dots"></i> Feedback</a>
    <% } %>

    <div class="trophy-card">
        <i class="fa-solid fa-trophy"></i>
        <div style="font-weight:700; font-size:14px;">Keep it up!</div>
        <small style="opacity:.8; font-size:11px;">You're doing great this semester.</small>
    </div>

    <a href="/logout" class="nav-link logout-link"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<!-- ================= MAIN ================= -->
<div class="main-content">

    <!-- Top navbar -->
    <div class="topbar">
        <div>
            <h4 class="page-title"><%= page.replace(/_/g, ' ') %></h4>
            <span class="welcome-text">Welcome back, <%= user.full_name %>! 👋</span>
        </div>
        <div class="topbar-tools">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted); font-size:13px;"></i>
                <input type="text" placeholder="Search...">
            </div>
            <button class="icon-btn"><i class="fa-regular fa-calendar"></i></button>
            <button class="icon-btn"><i class="fa-regular fa-bell"></i><span class="badge-dot">3</span></button>
            <button class="profile-btn">
                <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.full_name || 'User') %>&background=6366F1&color=fff" alt="avatar">
                <span>
                    <span class="p-name d-block"><%= user.full_name %></span>
                    <span class="p-role d-block"><%= user.role %></span>
                </span>
            </button>
        </div>
    </div>

    <!-- Success alert -->
    <% if (success_msg) { %>
        <div class="alert alert-success alert-dismissible fade show" style="border-radius:14px; border:none;">
            <i class="fa-solid fa-circle-check me-2"></i><%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- ============ PAGE CONTENT ============ -->

    <% if (page === 'dashboard') { %>
        <%
            let attPct;
            if (user.role === 'student' && typeof total_total !== 'undefined') {
                attPct = total_total > 0 ? Math.round((total_present / total_total) * 100) : 0;
            } else {
                attPct = (typeof att_count !== 'undefined' && att_count > 0) ? 87 : 0;
            }
        %>
        <div class="row g-3 mb-4">
            <div class="col">
                <div class="metric-card bg-purple">
                    <div class="m-icon"><i class="fa-solid fa-book"></i></div>
                    <h3><%= typeof total_courses !== 'undefined' ? total_courses : 12 %></h3>
                    <small>Total Courses</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-green">
                    <div class="m-icon"><i class="fa-solid fa-book-open"></i></div>
                    <h3><%= typeof total_subjects !== 'undefined' ? total_subjects : 36 %></h3>
                    <small>Total Subjects</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-orange">
                    <div class="m-icon"><i class="fa-solid fa-clipboard-user"></i></div>
                    <h3><%= attPct %>%</h3>
                    <small>Attendance</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-blue">
                    <div class="m-icon"><i class="fa-solid fa-user-graduate"></i></div>
                    <h3><%= typeof total_students !== 'undefined' ? total_students : 480 %></h3>
                    <small>Total Students</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-pink">
                    <div class="m-icon"><i class="fa-solid fa-user-tie"></i></div>
                    <h3><%= typeof total_staff !== 'undefined' ? total_staff : 25 %></h3>
                    <small>Total Staff</small>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Attendance Overview</h6>
                    <div style="position:relative; height:320px;">
                        <canvas id="attChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Performance Metrics</h6>
                    <div style="position:relative; height:320px;">
                        <canvas id="perfChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

    <% } else if (page === 'courses' || page === 'subjects') { %>
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Add New <%= page === 'courses' ? 'Course' : 'Subject' %></h6>
                    <form method="POST" action="/app?page=<%= page %>">
                        <input type="hidden" name="action" value="<%= page === 'courses' ? 'add_course' : 'add_subject' %>">
                        <div class="mb-3">
                            <label class="form-label"><%= page === 'courses' ? 'Course' : 'Subject' %> Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <% if (page === 'subjects') { %>
                            <div class="mb-3">
                                <label class="form-label">Course</label>
                                <select name="course_id" class="form-select" required>
                                    <option value="">-- Select Course --</option>
                                    <% courses.forEach(c => { %>
                                        <option value="<%= c._id %>"><%= c.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        <% } %>
                        <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-plus me-2"></i>Add</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">All <%= page === 'courses' ? 'Courses' : 'Subjects' %></h6>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <% if (page === 'subjects') { %><th>Course</th><% } %>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% const items = (page === 'courses') ? courses : subjects; %>
                                <% items.forEach((item, i) => { %>
                                    <tr>
                                        <td><%= i + 1 %></td>
                                        <td class="fw-semibold"><%= item.name %></td>
                                        <% if (page === 'subjects') { %>
                                            <td><span class="status-pill pill-green"><%= item.course_id ? item.course_id.name : 'N/A' %></span></td>
                                        <% } %>
                                        <td class="text-end">
                                            <a href="/app?delete=1&table=<%= page %>&id=<%= item._id %>&page=<%= page %>"
                                               class="btn btn-sm btn-outline-danger rounded-3"
                                               onclick="return confirm('Delete this record?')">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if (items.length === 0) { %>
                                    <tr><td colspan="4" class="text-center text-muted py-4">No records found.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    <% } else if (page === 'manage_staff' || page === 'manage_students') { %>
        <% const isStudents = (page === 'manage_students'); %>
        <% const userList = isStudents ? students : staffs; %>
        <div class="card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">All <%= isStudents ? 'Students' : 'Staff' %></h6>
                <button class="btn btn-indigo rounded-3" data-bs-toggle="modal" data-bs-target="#addUserModal">
                    <i class="fa-solid fa-plus me-2"></i>Add New <%= isStudents ? 'Student' : 'Staff' %>
                </button>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <% if (isStudents) { %><th>Course</th><% } %>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% userList.forEach(u => { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img class="avatar-sm" src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(u.full_name || 'U') %>&background=6366F1&color=fff">
                                        <span class="fw-semibold"><%= u.full_name %></span>
                                    </div>
                                </td>
                                <td><%= u.email %></td>
                                <td><%= u.gender || '—' %></td>
                                <% if (isStudents) { %>
                                    <td><span class="status-pill pill-green"><%= u.course_id ? u.course_id.name : 'N/A' %></span></td>
                                <% } %>
                                <td class="text-end">
                                    <a href="/app?delete=1&table=<%= isStudents ? 'students' : 'staff' %>&id=<%= u._id %>&page=<%= page %>"
                                       class="btn btn-sm btn-outline-danger rounded-3"
                                       onclick="return confirm('Delete this user?')">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (userList.length === 0) { %>
                            <tr><td colspan="5" class="text-center text-muted py-4">No records found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Add user modal -->
        <div class="modal fade" id="addUserModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:20px; border:none;">
                    <form method="POST" action="/app?page=<%= page %>">
                        <input type="hidden" name="action" value="<%= isStudents ? 'add_student' : 'add_staff' %>">
                        <div class="modal-header border-0">
                            <h6 class="modal-title fw-bold">Add New <%= isStudents ? 'Student' : 'Staff' %></h6>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="full_name" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" required>
                                <small class="text-muted">Default password: 123456</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Gender</label>
                                <select name="gender" class="form-select">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>
                            <% if (isStudents) { %>
                                <div class="mb-3">
                                    <label class="form-label">Course</label>
                                    <select name="course_id" class="form-select" required>
                                        <option value="">-- Select Course --</option>
                                        <% courses.forEach(c => { %>
                                            <option value="<%= c._id %>"><%= c.name %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            <% } %>
                            <div class="mb-3">
                                <label class="form-label">Address</label>
                                <textarea name="address" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-indigo rounded-3">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    <% } else if (page === 'manage_attendance' || page === 'take_attendance') { %>
        <div class="card p-4 mb-3">
            <h6 class="fw-bold mb-3">Select Class</h6>
            <form method="GET" action="/app" class="row g-3 align-items-end">
                <input type="hidden" name="page" value="<%= page %>">
                <div class="col-md-3">
                    <label class="form-label">Date</label>
                    <input type="date" name="fetch_date" class="form-control" value="<%= typeof fetch_date !== 'undefined' ? fetch_date : '' %>" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Course</label>
                    <select name="fetch_course" class="form-select" required>
                        <option value="">-- Select --</option>
                        <% courses.forEach(c => { %>
                            <option value="<%= c._id %>" <%= (typeof fetch_course !== 'undefined' && fetch_course == c._id) ? 'selected' : '' %>><%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Subject</label>
                    <select name="fetch_subject" class="form-select" required>
                        <option value="">-- Select --</option>
                        <% subjects.forEach(s => { %>
                            <option value="<%= s._id %>" <%= (typeof fetch_subject !== 'undefined' && fetch_subject == s._id) ? 'selected' : '' %>><%= s.name %> (<%= s.course_id ? s.course_id.name : 'N/A' %>)</option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-magnifying-glass me-2"></i>Fetch Students</button>
                </div>
            </form>
        </div>

        <% if (fetched_students.length > 0) { %>
            <div class="card p-4">
                <h6 class="fw-bold mb-3">Mark Attendance · <%= fetch_date %></h6>
                <form method="POST" action="/app?page=<%= page %>">
                    <input type="hidden" name="action" value="save_attendance">
                    <input type="hidden" name="date" value="<%= fetch_date %>">
                    <input type="hidden" name="course_id" value="<%= fetch_course %>">
                    <input type="hidden" name="subject_id" value="<%= fetch_subject %>">
                    <table class="table align-middle">
                        <thead><tr><th>Student</th><th class="text-center">Present</th><th class="text-center">Absent</th></tr></thead>
                        <tbody>
                            <% fetched_students.forEach(s => { %>
                                <% const cur = existing_attendance[s._id] || 'Present'; %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img class="avatar-sm" src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(s.full_name || 'S') %>&background=00B87C&color=fff">
                                            <span class="fw-semibold"><%= s.full_name %></span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <input class="form-check-input" type="radio" name="attendance[<%= s._id %>]" value="Present" <%= cur === 'Present' ? 'checked' : '' %>>
                                    </td>
                                    <td class="text-center">
                                        <input class="form-check-input" type="radio" name="attendance[<%= s._id %>]" value="Absent" <%= cur === 'Absent' ? 'checked' : '' %>>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-floppy-disk me-2"></i>Save Attendance</button>
                </form>
            </div>
        <% } %>

    <% } else if (page === 'manage_exams') { %>
        <div class="card p-4 mb-3">
            <h6 class="fw-bold mb-3">Select Class</h6>
            <form method="GET" action="/app" class="row g-3 align-items-end">
                <input type="hidden" name="page" value="manage_exams">
                <div class="col-md-4">
                    <label class="form-label">Course</label>
                    <select name="fetch_course" class="form-select" required>
                        <option value="">-- Select --</option>
                        <% courses.forEach(c => { %>
                            <option value="<%= c._id %>" <%= (typeof fetch_course !== 'undefined' && fetch_course == c._id) ? 'selected' : '' %>><%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Subject</label>
                    <select name="fetch_subject" class="form-select" required>
                        <option value="">-- Select --</option>
                        <% subjects.forEach(s => { %>
                            <option value="<%= s._id %>" <%= (typeof fetch_subject !== 'undefined' && fetch_subject == s._id) ? 'selected' : '' %>><%= s.name %> (<%= s.course_id ? s.course_id.name : 'N/A' %>)</option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-magnifying-glass me-2"></i>Fetch Students</button>
                </div>
            </form>
        </div>

        <% if (exam_students.length > 0) { %>
            <div class="card p-4">
                <h6 class="fw-bold mb-3">Enter Scores</h6>
                <form method="POST" action="/app?page=manage_exams">
                    <input type="hidden" name="action" value="save_scores">
                    <input type="hidden" name="subject_id" value="<%= fetch_subject %>">
                    <table class="table align-middle">
                        <thead><tr><th>Student</th><th style="width:200px;">Score (0-100)</th></tr></thead>
                        <tbody>
                            <% exam_students.forEach(s => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img class="avatar-sm" src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(s.full_name || 'S') %>&background=0075FF&color=fff">
                                            <span class="fw-semibold"><%= s.full_name %></span>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="number" min="0" max="100" class="form-control"
                                               name="score[<%= s._id %>]"
                                               value="<%= existing_scores[s._id] !== undefined ? existing_scores[s._id] : '' %>">
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-floppy-disk me-2"></i>Save Scores</button>
                </form>
            </div>
        <% } %>

    <% } else if (page === 'apply_leave') { %>
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Apply for Leave</h6>
                    <form method="POST" action="/app?page=apply_leave">
                        <input type="hidden" name="action" value="apply_leave">
                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            <input type="date" name="date" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reason</label>
                            <textarea name="message" class="form-control" rows="4" required></textarea>
                        </div>
                        <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-paper-plane me-2"></i>Submit Request</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">My Leave History</h6>
                    <table class="table align-middle">
                        <thead><tr><th>Date</th><th>Reason</th><th>Status</th></tr></thead>
                        <tbody>
                            <% (my_leaves || []).forEach(l => { %>
                                <tr>
                                    <td class="fw-semibold"><%= l.date %></td>
                                    <td><%= l.message %></td>
                                    <td>
                                        <% if (l.status === 'Approved') { %><span class="status-pill pill-green">Approved</span>
                                        <% } else if (l.status === 'Declined') { %><span class="status-pill pill-red">Declined</span>
                                        <% } else { %><span class="status-pill pill-yellow">Pending</span><% } %>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (!my_leaves || my_leaves.length === 0) { %>
                                <tr><td colspan="3" class="text-center text-muted py-4">No leave requests yet.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    <% } else if (page === 'notifications') { %>
        <div class="card p-4">
            <h6 class="fw-bold mb-3">Leave Requests</h6>
            <table class="table align-middle">
                <thead><tr><th>User</th><th>Role</th><th>Date</th><th>Reason</th><th>Status</th><th class="text-end">Action</th></tr></thead>
                <tbody>
                    <% (leaves || []).forEach(l => { %>
                        <tr>
                            <td class="fw-semibold"><%= l.user_id ? l.user_id.full_name : 'Unknown' %></td>
                            <td><span class="status-pill <%= l.role === 'staff' ? 'pill-green' : 'pill-yellow' %>" style="text-transform:capitalize;"><%= l.role %></span></td>
                            <td><%= l.date %></td>
                            <td><%= l.message %></td>
                            <td>
                                <% if (l.status === 'Approved') { %><span class="status-pill pill-green">Approved</span>
                                <% } else if (l.status === 'Declined') { %><span class="status-pill pill-red">Declined</span>
                                <% } else { %><span class="status-pill pill-yellow">Pending</span><% } %>
                            </td>
                            <td class="text-end">
                                <% if (l.status === 'Pending') { %>
                                    <form method="POST" action="/app?page=notifications" class="d-inline">
                                        <input type="hidden" name="action" value="update_leave">
                                        <input type="hidden" name="leave_id" value="<%= l._id %>">
                                        <input type="hidden" name="status" value="Approved">
                                        <button class="btn btn-sm btn-success rounded-3"><i class="fa-solid fa-check"></i></button>
                                    </form>
                                    <form method="POST" action="/app?page=notifications" class="d-inline">
                                        <input type="hidden" name="action" value="update_leave">
                                        <input type="hidden" name="leave_id" value="<%= l._id %>">
                                        <input type="hidden" name="status" value="Declined">
                                        <button class="btn btn-sm btn-danger rounded-3"><i class="fa-solid fa-xmark"></i></button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted" style="font-size:12px;">Processed</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (!leaves || leaves.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted py-4">No leave requests.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    <% } else if (page === 'notify') { %>
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-bullhorn me-2 text-primary"></i>Broadcast Notification</h6>
                    <form method="POST" action="/app?page=notify">
                        <input type="hidden" name="action" value="send_notification">
                        <div class="mb-3">
                            <label class="form-label">Audience</label>
                            <select name="type" class="form-select" required>
                                <option value="student">Students</option>
                                <option value="staff">Staff</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea name="message" class="form-control" rows="5" required></textarea>
                        </div>
                        <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-paper-plane me-2"></i>Send</button>
                    </form>
                </div>
            </div>
        </div>

    <% } else if (page === 'staff_notifs' || page === 'student_notifs') { %>
        <% if (notifs && notifs.length > 0) { %>
            <% notifs.forEach(n => { %>
                <div class="notif-card">
                    <div class="notif-icon"><i class="fa-solid fa-bell"></i></div>
                    <div>
                        <div class="fw-semibold"><%= n.message %></div>
                        <small class="text-muted"><i class="fa-regular fa-clock me-1"></i><%= new Date(n.created_at).toLocaleString() %></small>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="alert alert-info" style="border-radius:14px; border:none;">
                <i class="fa-solid fa-circle-info me-2"></i>No new notices.
            </div>
        <% } %>

    <% } else if (page === 'view_attendance' || page === 'my_attendance') { %>
        <% const rows = (page === 'view_attendance') ? (logs || []) : (my_att || []); %>
        <div class="card p-4">
            <h6 class="fw-bold mb-3"><%= page === 'view_attendance' ? 'Attendance Logs (Last 50)' : 'My Attendance' %></h6>
            <table class="table align-middle">
                <thead>
                    <tr>
                        <% if (page === 'view_attendance') { %><th>Student</th><% } %>
                        <th>Subject</th><th>Date</th><th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% rows.forEach(r => { %>
                        <tr>
                            <% if (page === 'view_attendance') { %>
                                <td class="fw-semibold"><%= r.student_id ? r.student_id.full_name : 'N/A' %></td>
                            <% } %>
                            <td><%= r.subject_id ? r.subject_id.name : 'N/A' %></td>
                            <td><%= r.date %></td>
                            <td>
                                <% if (r.status === 'Present') { %><span class="status-pill pill-green">Present</span>
                                <% } else { %><span class="status-pill pill-red">Absent</span><% } %>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (rows.length === 0) { %>
                        <tr><td colspan="4" class="text-center text-muted py-4">No attendance records found.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    <% } else if (page === 'exam_results') { %>
        <% if (scores && scores.length > 0) { %>
            <div class="row g-3">
                <% const borders = ['#6366F1', '#00B87C', '#FF9C00', '#0075FF', '#FF4C61']; %>
                <% scores.forEach((s, i) => { %>
                    <div class="col-md-4 col-lg-3">
                        <div class="score-card" style="border-top-color: <%= borders[i % borders.length] %>;">
                            <div class="fw-semibold text-muted mb-2"><%= s.subject_id ? s.subject_id.name : 'Subject' %></div>
                            <h1 class="fw-bold mb-0" style="color:var(--text-main);"><%= s.score %></h1>
                            <small class="text-muted">out of 100</small>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-info" style="border-radius:14px; border:none;">
                <i class="fa-solid fa-circle-info me-2"></i>No exam scores available yet.
            </div>
        <% } %>

    <% } else if (page === 'feedback') { %>
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-comment-dots me-2 text-primary"></i>Send Feedback</h6>
                    <form method="POST" action="/app?page=feedback">
                        <input type="hidden" name="action" value="send_feedback">
                        <div class="mb-3">
                            <label class="form-label">Your Message</label>
                            <textarea name="message" class="form-control" rows="6" placeholder="Share your thoughts with the administration..." required></textarea>
                        </div>
                        <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-paper-plane me-2"></i>Submit Feedback</button>
                    </form>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="alert alert-warning" style="border-radius:14px; border:none;">Page not found or you don't have access.</div>
    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<% if (page === 'dashboard') { %>
<script>
    // Attendance Overview (line)
    const labels = Array.from({ length: 31 }, (_, i) => 'May ' + (i + 1));
    const presentData = labels.map((_, i) => 35 + Math.round(8 * Math.sin(i / 3)) + (i % 5));
    const absentData = labels.map((_, i) => 8 + Math.round(4 * Math.cos(i / 4)) + (i % 3));

    new Chart(document.getElementById('attChart'), {
        type: 'line',
        data: {
            labels,
            datasets: [
                { label: 'Present', data: presentData, borderColor: '#00B87C', backgroundColor: 'rgba(0,184,124,0.08)', tension: 0.4, fill: true, pointRadius: 0 },
                { label: 'Absent', data: absentData, borderColor: '#FF4C61', backgroundColor: 'rgba(255,76,97,0.08)', tension: 0.4, fill: true, pointRadius: 0 }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } },
            scales: { x: { ticks: { maxTicksLimit: 8 }, grid: { display: false } }, y: { beginAtZero: true } }
        }
    });

    // Performance Metrics (doughnut)
    new Chart(document.getElementById('perfChart'), {
        type: 'doughnut',
        data: {
            labels: ['Excellent', 'Good', 'Needs Work'],
            datasets: [{ data: [55, 30, 15], backgroundColor: ['#00B87C', '#0075FF', '#FF4C61'], borderWidth: 0 }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>
<% } %>

</body>
</html>
